<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Sequence -->
    <record id="seq_referral_form" model="ir.sequence">
        <field name="name">Referral Form</field>
        <field name="code">referral.form</field>
        <field name="prefix">REF/%(year)s/</field>
        <field name="padding">4</field>
    </record>

    <!-- Referral Services (Form 9 service list) -->
    <record id="referral_service_child_protection" model="referral.service">
        <field name="name">Child Protection</field>
        <field name="sequence">1</field>
    </record>
    <record id="referral_service_gbv" model="referral.service">
        <field name="name">GBV</field>
        <field name="sequence">2</field>
    </record>
    <record id="referral_service_health" model="referral.service">
        <field name="name">Health</field>
        <field name="sequence">3</field>
    </record>
    <record id="referral_service_mhpss" model="referral.service">
        <field name="name">MHPSS</field>
        <field name="sequence">4</field>
    </record>
    <record id="referral_service_legal" model="referral.service">
        <field name="name">Legal</field>
        <field name="sequence">5</field>
    </record>
    <record id="referral_service_basic_needs" model="referral.service">
        <field name="name">Basic Needs</field>
        <field name="sequence">6</field>
    </record>
    <record id="referral_service_shelter" model="referral.service">
        <field name="name">Shelter</field>
        <field name="sequence">7</field>
    </record>
    <record id="referral_service_wash" model="referral.service">
        <field name="name">WASH</field>
        <field name="sequence">8</field>
    </record>
    <record id="referral_service_education" model="referral.service">
        <field name="name">Education</field>
        <field name="sequence">9</field>
    </record>
    <record id="referral_service_livelihood" model="referral.service">
        <field name="name">Livelihood</field>
        <field name="sequence">10</field>
    </record>
    <record id="referral_service_other" model="referral.service">
        <field name="name">Other</field>
        <field name="sequence">11</field>
    </record>

    <!-- Form View -->
    <record id="view_referral_form_form" model="ir.ui.view">
        <field name="name">referral.form.form</field>
        <field name="model">referral.form</field>
        <field name="arch" type="xml">
            <form string="Referral Form">
                <header>
                    <button name="action_confirm" string="Confirm" type="object"
                            class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_reset_draft" string="Reset to Draft" type="object"
                            invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="survivor_id"/>
                            <field name="priority" widget="radio"/>
                        </group>
                        <group>
                            <field name="date_identification"/>
                            <field name="referral_date"/>
                        </group>
                    </group>
                    <group>
                        <group string="Referred By (Referring Agency)">
                            <field name="ref_sector"/>
                            <field name="ref_agency"/>
                            <field name="ref_location"/>
                            <field name="ref_focal_point"/>
                            <field name="ref_email"/>
                            <field name="ref_phone"/>
                        </group>
                        <group string="Referred To (Receiving Agency)">
                            <field name="recv_sector"/>
                            <field name="recv_agency"/>
                            <field name="recv_location"/>
                            <field name="recv_focal_point"/>
                            <field name="recv_email"/>
                            <field name="recv_phone"/>
                        </group>
                    </group>
                    <group>
                        <field name="service_ids" widget="many2many_tags"/>
                    </group>
                    <notebook>
                        <page string="Client Information" name="client">
                            <group>
                                <field name="consent_obtained"/>
                            </group>
                            <group invisible="not consent_obtained">
                                <group>
                                    <field name="client_name"/>
                                    <field name="client_address"/>
                                    <field name="client_phone"/>
                                </group>
                                <group>
                                    <field name="client_phone_owner"/>
                                    <field name="contact_method"/>
                                    <field name="preferred_contact_datetime"/>
                                </group>
                            </group>
                            <group string="Client Bio">
                                <group>
                                    <field name="unhcr_no"/>
                                    <field name="population_type"/>
                                    <field name="client_age"/>
                                </group>
                                <group>
                                    <field name="client_sex"/>
                                    <field name="disability_status"/>
                                </group>
                            </group>
                        </page>
                        <page string="Caregiver Information" name="caregiver">
                            <group>
                                <group>
                                    <field name="caregiver_name"/>
                                    <field name="caregiver_affiliation"/>
                                    <field name="caregiver_relationship"/>
                                </group>
                                <group>
                                    <field name="caregiver_address"/>
                                    <field name="caregiver_phone"/>
                                    <field name="caregiver_informed"/>
                                    <field name="caregiver_informed_explanation"
                                           invisible="not caregiver_informed"/>
                                </group>
                            </group>
                        </page>
                        <page string="Case Narrative" name="narrative">
                            <field name="case_narrative"
                                   placeholder="Minimum information the receiving agency needs, plus any accessibility / reasonable-accommodation measures..."/>
                        </page>
                        <page string="Consent to Release Information" name="consent">
                            <group>
                                <group>
                                    <field name="consent_client_name"/>
                                    <field name="consent_client_signature"/>
                                </group>
                                <group>
                                    <field name="consent_provider_name"/>
                                    <field name="consent_provider_signature"/>
                                    <field name="consent_date"/>
                                </group>
                            </group>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="notes" placeholder="Additional notes..."/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Tree View -->
    <record id="view_referral_form_tree" model="ir.ui.view">
        <field name="name">referral.form.tree</field>
        <field name="model">referral.form</field>
        <field name="arch" type="xml">
            <tree string="Referral Forms"
                  decoration-danger="priority == 'high'"
                  decoration-warning="priority == 'medium'">
                <field name="name"/>
                <field name="survivor_id"/>
                <field name="priority"/>
                <field name="referral_date"/>
                <field name="recv_agency"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-success="state == 'confirmed'"/>
            </tree>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_referral_form_search" model="ir.ui.view">
        <field name="name">referral.form.search</field>
        <field name="model">referral.form</field>
        <field name="arch" type="xml">
            <search string="Referral Forms">
                <field name="name"/>
                <field name="survivor_id"/>
                <field name="recv_agency"/>
                <filter string="High Risk" name="high" domain="[('priority', '=', 'high')]"/>
                <filter string="Medium Risk" name="medium" domain="[('priority', '=', 'medium')]"/>
                <filter string="Low Risk" name="low" domain="[('priority', '=', 'low')]"/>
                <separator/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Confirmed" name="confirmed" domain="[('state', '=', 'confirmed')]"/>
                <group expand="0" string="Group By">
                    <filter string="Survivor" name="group_survivor"
                            context="{'group_by': 'survivor_id'}"/>
                    <filter string="Priority" name="group_priority"
                            context="{'group_by': 'priority'}"/>
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Referral Date" name="group_date"
                            context="{'group_by': 'referral_date'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_referral_form" model="ir.actions.act_window">
        <field name="name">Referral Forms</field>
        <field name="res_model">referral.form</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first referral form
            </p>
        </field>
    </record>

    <!-- Menu -->
    <menuitem id="menu_referral_form" name="Referral Form"
              parent="menu_survivor_case_root" action="action_referral_form" sequence="19"/>
</odoo>
