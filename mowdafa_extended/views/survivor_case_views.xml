<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Sequence -->
    <record id="seq_survivor_case" model="ir.sequence">
        <field name="name">Survivor Case</field>
        <field name="code">survivor.case</field>
        <field name="prefix">SC/%(year)s/</field>
        <field name="padding">4</field>
    </record>

    <!-- Form View -->
    <record id="view_survivor_case_form" model="ir.ui.view">
        <field name="name">survivor.case.form</field>
        <field name="model">survivor.case</field>
        <field name="arch" type="xml">
            <form string="Survivor Case">
                <header>
                    <button name="action_confirm" string="Confirm" type="object"
                            class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_reset_draft" string="Reset to Draft" type="object"
                            invisible="state == 'draft'"/>
                    <button name="action_open_admission" string="Admission Form" type="object"
                            class="oe_highlight"
                            invisible="state != 'confirmed' or admission_count &gt; 0"/>
                    <button name="%(mowdafa_extended.action_report_consent_for_services)d"
                            string="Consent Report" type="action"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_admissions" type="object"
                                class="oe_stat_button" icon="fa-book"
                                invisible="admission_count == 0">
                            <field name="admission_count" widget="statinfo"
                                   string="Admissions"/>
                        </button>
                        <button name="action_view_action_plans" type="object"
                                class="oe_stat_button" icon="fa-tasks"
                                invisible="action_plan_count == 0">
                            <field name="action_plan_count" widget="statinfo"
                                   string="Action Plans"/>
                        </button>
                        <button name="action_view_followups" type="object"
                                class="oe_stat_button" icon="fa-calendar-check-o"
                                invisible="followup_count == 0">
                            <field name="followup_count" widget="statinfo"
                                   string="Follow-ups"/>
                        </button>
                        <button name="action_view_referrals" type="object"
                                class="oe_stat_button" icon="fa-share-square-o"
                                invisible="referral_count == 0">
                            <field name="referral_count" widget="statinfo"
                                   string="Referrals"/>
                        </button>
                        <button name="action_view_closures" type="object"
                                class="oe_stat_button" icon="fa-archive"
                                invisible="closure_count == 0">
                            <field name="closure_count" widget="statinfo"
                                   string="Case Closures"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="case_id" options="{'no_create': True}"/>
                            <field name="survivor_id" required="1"/>
                            <field name="survivor_age" invisible="not survivor_id"/>
                            <field name="is_minor" invisible="1"/>
                            <field name="case_worker_id" required="1"/>
                            <field name="date"/>
                        </group>
                        <group>
                            <field name="guardian_name"
                                   invisible="not is_minor"
                                   required="is_minor"/>
                        </group>
                    </group>
                    <group string="Signatures">
                        <group>
                            <field name="guardian_signature" invisible="not is_minor"/>
                            <field name="case_worker_signature"/>
                        </group>
                        <group>
                            <field name="survivor_signature"/>
                        </group>
                    </group>
                    <separator string="Notes"/>
                    <field name="notes" nolabel="1" placeholder="Additional notes..."/>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Tree View -->
    <record id="view_survivor_case_tree" model="ir.ui.view">
        <field name="name">survivor.case.tree</field>
        <field name="model">survivor.case</field>
        <field name="arch" type="xml">
            <tree string="Survivor Cases">
                <field name="name"/>
                <field name="survivor_id"/>
                <field name="case_worker_id"/>
                <field name="guardian_name"/>
                <field name="date"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-success="state == 'confirmed'"/>
            </tree>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_survivor_case_search" model="ir.ui.view">
        <field name="name">survivor.case.search</field>
        <field name="model">survivor.case</field>
        <field name="arch" type="xml">
            <search string="Survivor Cases">
                <field name="name"/>
                <field name="survivor_id"/>
                <field name="case_worker_id"/>
                <field name="guardian_name"/>
                <group expand="0" string="Group By">
                    <filter string="Case Worker" name="group_case_worker"
                            context="{'group_by': 'case_worker_id'}"/>
                    <filter string="Status" name="group_state"
                            context="{'group_by': 'state'}"/>
                    <filter string="Date" name="group_date"
                            context="{'group_by': 'date'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_survivor_case" model="ir.actions.act_window">
        <field name="name">Consent Form</field>
        <field name="res_model">survivor.case</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first survivor case
            </p>
        </field>
    </record>

    <!-- Menu -->
    <menuitem id="menu_survivor_case_root" name="GBV" sequence="60"
              web_icon="mowdafa_extended,static/description/icon.png"/>
<!-- Consent Form menu removed: consents are created from the case
     (Create Consent button) and reached via the case smart buttons. -->
</odoo>
