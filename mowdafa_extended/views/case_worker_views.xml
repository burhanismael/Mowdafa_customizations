<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form View -->
    <record id="view_case_worker_form" model="ir.ui.view">
        <field name="name">case.worker.form</field>
        <field name="model">case.worker</field>
        <field name="arch" type="xml">
            <form string="Case Worker">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="employee_id" placeholder="Employee"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="institution"/>
                            <field name="location"/>
                        </group>
                        <group>
                            <field name="id_no"/>
                            <field name="code" readonly="1"/>
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Tree View -->
    <record id="view_case_worker_tree" model="ir.ui.view">
        <field name="name">case.worker.tree</field>
        <field name="model">case.worker</field>
        <field name="arch" type="xml">
            <tree string="Case Workers">
                <field name="employee_id"/>
                <field name="institution"/>
                <field name="location"/>
                <field name="id_no"/>
                <field name="code"/>
            </tree>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_case_worker_search" model="ir.ui.view">
        <field name="name">case.worker.search</field>
        <field name="model">case.worker</field>
        <field name="arch" type="xml">
            <search string="Case Workers">
                <field name="employee_id"/>
                <field name="code"/>
                <field name="institution"/>
                <field name="location"/>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_case_worker" model="ir.actions.act_window">
        <field name="name">Case Workers</field>
        <field name="res_model">case.worker</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[]</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first case worker
            </p>
        </field>
    </record>

    <!-- Menu -->
    <menuitem id="menu_case_worker" name="Case Worker"
              parent="menu_survivor_case_root" action="action_case_worker" sequence="20"/>
</odoo>
