<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Sequence -->
    <record id="seq_action_plan" model="ir.sequence">
        <field name="name">Action Plan</field>
        <field name="code">action.plan</field>
        <field name="prefix">AP/%(year)s/</field>
        <field name="padding">4</field>
    </record>

    <!-- Form View -->
    <record id="view_action_plan_form" model="ir.ui.view">
        <field name="name">action.plan.form</field>
        <field name="model">action.plan</field>
        <field name="arch" type="xml">
            <form string="Action Plan">
                <header>
                    <button name="action_confirm" string="Confirm" type="object"
                            class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_create_followup" string="Create Follow-up Form" type="object"
                            class="oe_highlight"
                            invisible="state != 'confirmed' or can_provide_services != 'yes'"/>
                    <button name="action_create_referral" string="Create Referral Form" type="object"
                            class="oe_highlight"
                            invisible="state != 'confirmed' or can_provide_services != 'no'"/>
                    <button name="action_reset_draft" string="Reset to Draft" type="object"
                            invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_consent_forms" type="object"
                                class="oe_stat_button" icon="fa-file-text-o"
                                invisible="consent_count == 0">
                            <field name="consent_count" widget="statinfo" string="Consent Form"/>
                        </button>
                        <button name="action_view_admissions" type="object"
                                class="oe_stat_button" icon="fa-book"
                                invisible="admission_count == 0">
                            <field name="admission_count" widget="statinfo" string="Admissions"/>
                        </button>
                        <button name="action_view_followups" type="object"
                                class="oe_stat_button" icon="fa-calendar-check-o"
                                invisible="followup_count == 0">
                            <field name="followup_count" widget="statinfo" string="Follow-ups"/>
                        </button>
                        <button name="action_view_referrals" type="object"
                                class="oe_stat_button" icon="fa-share-square-o"
                                invisible="referral_count == 0">
                            <field name="referral_count" widget="statinfo" string="Referrals"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="survivor_id"/>
                            <field name="case_worker_id"/>
                            <field name="date"/>
                            <field name="can_provide_services"/>
                        </group>
                        <group>
                            <field name="followup_datetime"/>
                            <field name="followup_location"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Action Points / Goals" name="goals">
                            <field name="goal_ids">
                                <tree editable="bottom">
                                    <field name="goal"/>
                                    <field name="who"/>
                                    <field name="by_when"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Signatures" name="signatures">
                            <group>
                                <group>
                                    <field name="case_worker_signature"/>
                                    <field name="case_worker_signature_date"/>
                                </group>
                                <group>
                                    <field name="survivor_signature"/>
                                    <field name="client_signature_date"/>
                                </group>
                            </group>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="notes" placeholder="Additional notes..."/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Tree View -->
    <record id="view_action_plan_tree" model="ir.ui.view">
        <field name="name">action.plan.tree</field>
        <field name="model">action.plan</field>
        <field name="arch" type="xml">
            <tree string="Action Plans">
                <field name="name"/>
                <field name="survivor_id"/>
                <field name="case_worker_id"/>
                <field name="date"/>
                <field name="followup_datetime"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-success="state == 'confirmed'"/>
            </tree>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_action_plan_search" model="ir.ui.view">
        <field name="name">action.plan.search</field>
        <field name="model">action.plan</field>
        <field name="arch" type="xml">
            <search string="Action Plans">
                <field name="name"/>
                <field name="survivor_id"/>
                <field name="case_worker_id"/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Confirmed" name="confirmed" domain="[('state', '=', 'confirmed')]"/>
                <group expand="0" string="Group By">
                    <filter string="Caseworker" name="group_case_worker"
                            context="{'group_by': 'case_worker_id'}"/>
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Date" name="group_date" context="{'group_by': 'date'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_action_plan" model="ir.actions.act_window">
        <field name="name">Action Plans</field>
        <field name="res_model">action.plan</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first action plan
            </p>
        </field>
    </record>

    <!-- Menu -->
    <menuitem id="menu_action_plan" name="Action Plan"
              parent="menu_survivor_case_root" action="action_action_plan" sequence="17"/>
</odoo>
