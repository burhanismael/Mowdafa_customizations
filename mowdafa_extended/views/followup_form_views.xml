<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Sequence -->
    <record id="seq_followup_form" model="ir.sequence">
        <field name="name">Follow-up Form</field>
        <field name="code">followup.form</field>
        <field name="prefix">FU/%(year)s/</field>
        <field name="padding">4</field>
    </record>

    <!-- Form View -->
    <record id="view_followup_form_form" model="ir.ui.view">
        <field name="name">followup.form.form</field>
        <field name="model">followup.form</field>
        <field name="arch" type="xml">
            <form string="Follow-up Form">
                <header>
                    <button name="action_confirm" string="Confirm" type="object"
                            class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_reset_draft" string="Reset to Draft" type="object"
                            invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="survivor_id"/>
                            <field name="case_worker_id"/>
                            <field name="date"/>
                        </group>
                        <group>
                            <field name="next_followup_datetime"/>
                            <field name="next_followup_location"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Progress Towards Goals" name="goals">
                            <field name="goal_line_ids">
                                <tree editable="bottom">
                                    <field name="domain_type"/>
                                    <field name="status"/>
                                    <field name="explanation"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Re-assessing Safety" name="safety">
                            <group>
                                <group>
                                    <field name="risk_at_home"/>
                                    <field name="risk_at_home_action"
                                           invisible="not risk_at_home"/>
                                </group>
                                <group>
                                    <field name="risk_in_community"/>
                                    <field name="risk_in_community_action"
                                           invisible="not risk_in_community"/>
                                </group>
                            </group>
                        </page>
                        <page string="Final Assessment" name="assessment">
                            <group>
                                <group>
                                    <field name="safety_stable"/>
                                    <field name="safety_stable_note"
                                           invisible="not safety_stable"/>
                                    <field name="health_stable"/>
                                    <field name="health_stable_note"
                                           invisible="not health_stable"/>
                                    <field name="psychosocial_improved"/>
                                    <field name="psychosocial_improved_note"
                                           invisible="not psychosocial_improved"/>
                                </group>
                                <group>
                                    <field name="justice_secured"/>
                                    <field name="justice_secured_note"
                                           invisible="not justice_secured"/>
                                    <field name="other_intervention_needed"/>
                                    <field name="other_intervention_note"
                                           invisible="not other_intervention_needed"/>
                                </group>
                            </group>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="notes" placeholder="Additional notes..."/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Tree View -->
    <record id="view_followup_form_tree" model="ir.ui.view">
        <field name="name">followup.form.tree</field>
        <field name="model">followup.form</field>
        <field name="arch" type="xml">
            <tree string="Follow-up Forms">
                <field name="name"/>
                <field name="survivor_id"/>
                <field name="case_worker_id"/>
                <field name="date"/>
                <field name="next_followup_datetime"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-success="state == 'confirmed'"/>
            </tree>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_followup_form_search" model="ir.ui.view">
        <field name="name">followup.form.search</field>
        <field name="model">followup.form</field>
        <field name="arch" type="xml">
            <search string="Follow-up Forms">
                <field name="name"/>
                <field name="survivor_id"/>
                <field name="case_worker_id"/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Confirmed" name="confirmed" domain="[('state', '=', 'confirmed')]"/>
                <group expand="0" string="Group By">
                    <filter string="Survivor" name="group_survivor"
                            context="{'group_by': 'survivor_id'}"/>
                    <filter string="Caseworker" name="group_case_worker"
                            context="{'group_by': 'case_worker_id'}"/>
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Date" name="group_date" context="{'group_by': 'date'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_followup_form" model="ir.actions.act_window">
        <field name="name">Follow-up Forms</field>
        <field name="res_model">followup.form</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first follow-up form
            </p>
        </field>
    </record>

    <!-- Menu -->
    <menuitem id="menu_followup_form" name="Follow-up Form"
              parent="menu_survivor_case_root" action="action_followup_form" sequence="18"/>
</odoo>
