                            <field name="by_organisation"/>
                            <field name="by_name"/>
                            <field name="by_position"/>
                            <field name="by_location"/>
                            <field name="by_contact" string="Contact"/>
                            <field name="to_institution"/>
                            <field name="received_by"/>
                        </group>
                        <group>
                            <field name="received_role"/>
                            <field name="received_contact" string="Contact"/>
                            <field name="received_address"/>
                            <field name="sign_handing_over"/>
                            <field name="sign_child"/>
                            <field name="sign_receiver"/>
                            <field name="sign_witness"/>
                            <field name="notes"/>
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

