<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="seq_cp_placement" model="ir.sequence">
        <field name="name">cp.placement</field>
        <field name="code">cp.placement</field>
        <field name="prefix">PLC/%(year)s/</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="view_cp_placement_form" model="ir.ui.view">
        <field name="name">cp.placement.form</field>
        <field name="model">cp.placement</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="case_id"/>
                            <field name="type"/>
                            <field name="requires_daily"/>
                            <field name="date_start"/>
                        </group>
                        <group>
                            <field name="date_end"/>
                            <field name="location"/>
                            <field name="notes"/>
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

