<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Sequence: CP/2026/0001 -->
    <record id="seq_cp_case" model="ir.sequence">
        <field name="name">Child Protection Case</field>
        <field name="code">cp.case</field>
        <field name="prefix">CP/%(year)s/</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
    </record>

    <!-- Form -->
    <record id="view_cp_case_form" model="ir.ui.view">
        <field name="name">cp.case.form</field>
        <field name="model">cp.case</field>
        <field name="arch" type="xml">
            <form string="Child Protection Case">
                <header>
                    <field name="adult_verified" invisible="1"/>
                    <field name="child_verified" invisible="1"/>
                    <field name="verification_conflict" invisible="1"/>
                    <button name="action_create_handover" type="object"
                        string="Create Hand-over" class="btn-primary"
                        invisible="stage != 'handover' or handover_count &gt; 0"/>
                    <button name="action_create_registration" type="object"
                        string="Create Registration" class="btn-primary"
                        invisible="stage != 'registration' or registration_count &gt; 0"/>
                    <button name="action_create_verification_adult" type="object"
                        string="Adult Verification" class="btn-primary"
                        invisible="stage != 'verification' or adult_verified"/>
                    <button name="action_create_verification_child" type="object"
                        string="Child Verification" class="btn-primary"
                        invisible="stage != 'verification' or child_verified"/>
                    <button name="action_create_reunification" type="object"
                        string="Create Reunification" class="btn-primary"
                        invisible="stage != 'in_care' or reunification_count &gt; 0 or recommendation not in ('reunification', 'reunification_support')"/>
                    <button name="action_create_followup_visit" type="object"
                        string="New Follow-up Visit" class="btn-primary"
                        invisible="stage not in ('reunification', 'followup')"/>
                    <field name="stage" widget="statusbar" readonly="1"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_documents" type="object"
                                class="oe_stat_button" icon="fa-paperclip">
                            <field name="attachment_count" widget="statinfo"
                                   string="Documents"/>
                        </button>
                        <button name="action_view_handovers" type="object"
                                class="oe_stat_button" icon="fa-exchange"
                                invisible="handover_count == 0">
                            <field name="handover_count" widget="statinfo" string="Hand-over"/>
                        </button>
                        <button name="action_view_registrations" type="object"
                                class="oe_stat_button" icon="fa-id-card-o"
                                invisible="registration_count == 0">
                            <field name="registration_count" widget="statinfo" string="Registration"/>
                        </button>
                        <button name="action_view_verifications" type="object"
                                class="oe_stat_button" icon="fa-check-square-o"
                                invisible="verification_count == 0">
                            <field name="verification_count" widget="statinfo" string="Verifications"/>
                        </button>
                        <button name="action_view_placements" type="object"
                                class="oe_stat_button" icon="fa-home"
                                invisible="placement_count == 0">
                            <field name="placement_count" widget="statinfo" string="Placements"/>
                        </button>
                        <button name="action_view_psychosocial" type="object"
                                class="oe_stat_button" icon="fa-heart-o"
                                invisible="psychosocial_count == 0">
                            <field name="psychosocial_count" widget="statinfo" string="Psychosocial"/>
                        </button>
                        <button name="action_view_reunifications" type="object"
                                class="oe_stat_button" icon="fa-handshake-o"
                                invisible="reunification_count == 0">
                            <field name="reunification_count" widget="statinfo" string="Reunification"/>
                        </button>
                        <button name="action_view_followup_visits" type="object"
                                class="oe_stat_button" icon="fa-calendar-check-o"
                                invisible="followup_visit_count == 0">
                            <field name="followup_visit_count" widget="statinfo" string="Follow-ups"/>
                        </button>
                    </div>
                    <field name="photo" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group string="1 · Child Identification">
                        <group>
                            <field name="child_name" placeholder="Not yet named"/>
                            <field name="sex"/>
                            <field name="date_of_birth"/>
                            <field name="dob_estimated"/>
                            <field name="age_years"/>
                        </group>
                        <group>
                            <field name="nationality"/>
                            <field name="population_group"/>
                            <field name="disability"/>
                        </group>
                    </group>
                    <group string="Location — for the report">
                        <group>
                            <field name="region_id" options="{'no_create_edit': True}"/>
                            <field name="district_id" options="{'no_create_edit': True}"/>
                        </group>
                        <group>
                            <field name="date_identified"/>
                            <field name="referral_source"/>
                        </group>
                    </group>
                    <group>
                        <group string="Protection Concern">
                            <field name="protection_concern"/>
                            <field name="concern_description"/>
                        </group>
                        <group string="Safety &amp; Risk">
                            <field name="risk_level"/>
                            <field name="immediate_risk"/>
                            <field name="risk_factors"/>
                        </group>
                    </group>
                    <group string="Case Management — MOWDAFA">
                        <group>
                            <field name="case_worker_id" options="{'no_create_edit': True}"/>
                            <field name="supervisor_id" options="{'no_create_edit': True}"/>
                        </group>
                        <group>
                            <field name="placement_type"/>
                            <field name="recommendation"/>
                        </group>
                    </group>
                    <group string="Verification Gate">
                        <group>
                            <field name="verification_conflict"
                                   invisible="not verification_conflict"/>
                            <field name="supervisor_decision"
                                   invisible="not verification_conflict and not supervisor_decision"/>
                            <field name="supervisor_reason"
                                   invisible="not verification_conflict and not supervisor_decision"
                                   required="supervisor_decision != False"/>
                        </group>
                    </group>
                    <separator string="Notes"/>
                    <field name="notes" nolabel="1" placeholder="Case notes…"/>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- List -->
    <record id="view_cp_case_tree" model="ir.ui.view">
        <field name="name">cp.case.tree</field>
        <field name="model">cp.case</field>
        <field name="arch" type="xml">
            <tree string="Child Protection Cases">
                <field name="name"/>
                <field name="child_name" string="Child"/>
                <field name="sex" optional="hide"/>
                <field name="age_years" optional="hide"/>
                <field name="region_id"/>
                <field name="district_id" optional="show"/>
                <field name="protection_concern"/>
                <field name="risk_level" widget="badge"
                       decoration-danger="risk_level in ('critical', 'high')"
                       decoration-warning="risk_level == 'moderate'"
                       decoration-success="risk_level == 'low'"/>
                <field name="stage" widget="badge"/>
            </tree>
        </field>
    </record>

    <!-- Kanban: the care pipeline, six stages.
         Risk is a badge, the recommendation is the stripe — different
         questions, so they never share a colour or a corner. -->
    <record id="view_cp_case_kanban" model="ir.ui.view">
        <field name="name">cp.case.kanban</field>
        <field name="model">cp.case</field>
        <field name="arch" type="xml">
            <kanban default_group_by="stage" quick_create="false">
                <field name="name"/>
                <field name="stage"/>
                <field name="risk_level"/>
                <field name="recommendation"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click p-0 d-flex">
                            <div t-attf-style="width: 4px; flex: 0 0 4px; background: {{
                                    record.recommendation.raw_value === 'reunification' ? '#1E7A44'
                                    : record.recommendation.raw_value === 'reunification_support' ? '#2E75B6'
                                    : record.recommendation.raw_value === 'alt_care' ? '#8C560D'
                                    : record.recommendation.raw_value === 'tracing' ? '#C0392B'
                                    : '#D3D7DA' }}"/>
                            <div class="p-2 flex-grow-1">
                                <strong class="font-monospace text-primary">
                                    <field name="name"/>
                                </strong>
                                <div class="fw-bold mt-1">
                                    <t t-if="record.child_name.value">
                                        <field name="child_name"/>
                                    </t>
                                    <t t-else="">
                                        <span class="text-muted fst-italic">Not yet named</span>
                                    </t>
                                </div>
                                <div class="text-muted small">
                                    <t t-if="record.sex.value"><field name="sex"/> · </t>
                                    <t t-if="record.age_years.raw_value"><field name="age_years"/></t>
                                </div>
                                <div class="text-muted small"><field name="district_id"/></div>
                                <div class="mt-2">
                                    <span t-if="record.risk_level.raw_value"
                                          t-attf-class="badge me-1 {{
                                            ['critical','high'].includes(record.risk_level.raw_value) ? 'text-bg-danger'
                                            : record.risk_level.raw_value === 'moderate' ? 'text-bg-warning'
                                            : 'text-bg-success' }}">
                                        <field name="risk_level"/>
                                    </span>
                                    <span t-if="record.recommendation.raw_value"
                                          class="badge text-bg-light border">
                                        <field name="recommendation"/>
                                    </span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Search -->
    <record id="view_cp_case_search" model="ir.ui.view">
        <field name="name">cp.case.search</field>
        <field name="model">cp.case</field>
        <field name="arch" type="xml">
            <search string="Child Protection Cases">
                <field name="name"/>
                <field name="child_name"/>
                <filter string="Critical / High Risk" name="high_risk"
                        domain="[('risk_level', 'in', ('critical', 'high'))]"/>
                <group expand="0" string="Group By">
                    <filter string="Stage" name="group_stage"
                            context="{'group_by': 'stage'}"/>
                    <filter string="Region" name="group_region"
                            context="{'group_by': 'region_id'}"/>
                    <filter string="Concern" name="group_concern"
                            context="{'group_by': 'protection_concern'}"/>
                    <filter string="Risk Level" name="group_risk"
                            context="{'group_by': 'risk_level'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_cp_case_managed" model="ir.actions.act_window">
        <field name="name">Cases</field>
        <field name="res_model">cp.case</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="domain">[]</field>
        <field name="context">{}</field>
        <field name="search_view_id" ref="view_cp_case_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Open a child's file</p>
            <p>Children MOWDAFA cares for directly — the full journey
               from hand-over to reunification.</p>
        </field>
    </record>

    <record id="action_cp_dashboard" model="ir.actions.client">
        <field name="name">CP Dashboard</field>
        <field name="tag">mowdafa_child_protection.cp_dashboard</field>
    </record>

    <!-- Menus -->
    <menuitem id="menu_cp_root" name="Child Protection" sequence="61"
              web_icon="mowdafa_extended,static/description/icon.png"/>
    <menuitem id="menu_cp_dashboard" name="Dashboard"
              parent="menu_cp_root" action="action_cp_dashboard" sequence="1"/>
    <menuitem id="menu_cp_case_managed" name="Cases"
              parent="menu_cp_root" action="action_cp_case_managed" sequence="5"/>
</odoo>
